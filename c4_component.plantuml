@startuml
!include <C4/C4_Component>

title Диаграмма компонентов контейнера "Игровой сервис"

' Внешние системы
Container(web_app, "Веб-приложение", "JS, React/Vue", "Интерфейс")
ContainerDb(db, "База данных", "PostgreSQL", "Хранилище")
ContainerDb(cache, "Redis", "Broker/Cache", "Очередь задач")

Container_Boundary(api_app, "Игровой сервис (FastAPI)") {
    ' Компоненты (бывшие Controllers/Routers)
    Component(api_router, "API Router", "FastAPI", "Обработка HTTP запросов и маршрутизация")
    
    ' Компоненты (бывшие Service Layer)
    Component(task_manager, "Task Manager", "Python Class", "Управление жизненным циклом квестов")
    Component(rpg_engine, "RPG Engine", "Python Class", "Расчет опыта, уровней и наград")
    Component(duel_manager, "Duel Manager", "Python Class", "Механика и логика дуэлей")
    Component(shop_service, "Shop Service", "Python Class", "Обработка внутриигровых покупок")
    Component(report_gen, "Report Generator", "Python Class", "Генерация документов (Excel/PDF)")
    
    ' Компонент доступа к данным
    Component(repo, "Data Repository", "SQLAlchemy", "Доступ к БД и абстракция данных")
}

' Связи внешние -> API
Rel(web_app, api_router, "Запросы (Auth, Tasks, Game, Reports)", "JSON/HTTPS")

' Связи внутри API
Rel(api_router, task_manager, "Действия с задачами")
Rel(api_router, duel_manager, "Запуск дуэлей")
Rel(api_router, shop_service, "Покупки")
Rel(api_router, report_gen, "Заказ отчетов")
Rel(api_router, repo, "Аутентификация")

Rel(task_manager, rpg_engine, "Начисление XP")
Rel(duel_manager, rpg_engine, "Сравнение характеристик")

Rel(task_manager, repo, "Сохранение задач")
Rel(rpg_engine, repo, "Обновление профиля")
Rel(shop_service, repo, "Списание валюты")
Rel(duel_manager, repo, "Логи дуэлей")
Rel(report_gen, repo, "Сбор статистики")

' Связи наружу
Rel(repo, db, "SQL запросы", "TCP/IP")
Rel(task_manager, cache, "Очередь синхронизации", "RESP")
Rel(rpg_engine, cache, "События/Уведомления", "RESP")
Rel(report_gen, cache, "Фоновые отчеты", "RESP")

@enduml